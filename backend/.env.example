# Copy to .env for local development or to .env.production for deployment.
# See DEPLOYMENT.md for guidance on generating production secrets.

NODE_ENV=development
PORT=4000

# Local Postgres example:
# DATABASE_URL="postgresql://postgres:password@localhost:5432/myc_ops?schema=public"
DATABASE_URL=

# Only required when running behind a connection pooler (Supabase, PgBouncer).
# Leave blank for direct connections.
DIRECT_URL=

JWT_SECRET=change-me-to-a-random-string
JWT_REFRESH_SECRET=change-me-to-another-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Origin(s) allowed to call this API. Comma-separated for multiple.
FRONTEND_URL=http://localhost:3000